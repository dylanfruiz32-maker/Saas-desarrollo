---
import PageLayout from '../layout/PageLayout.astro';
import PublicRoute from '../layout/PublicRoute.astro';
import { menuItems } from '../components/navigation/utils.js';
import { stockColor } from '../features/dashboard/utils';

// 1. Simulación de datos del SaaS
const nombreTienda = 'Perfumería & Calzado Elegance';
const divisa = '$';

const productosCriticos = [
  {
    id: 101,
    nombre: 'Perfume Bleu de Chanel 100ml',
    categoria: 'Perfumes',
    stock: 2,
    minimo: 5,
  },
  {
    id: 102,
    nombre: 'Zapatos Oxford Cuero Negro (Talla 42)',
    categoria: 'Zapatos',
    stock: 1,
    minimo: 4,
  },
  {
    id: 103,
    nombre: 'Perfume Versace Eros Flame',
    categoria: 'Perfumes',
    stock: 0,
    minimo: 3,
  },
  {
    id: 104,
    nombre: 'Tacones Aguja Rojo Pasión (Talla 38)',
    categoria: 'Zapatos',
    stock: 3,
    minimo: 6,
  },
];

const metricas = {
  ventasHoy: '420.00',
  totalProductos: 148,
  alertasRestock: productosCriticos.length,
};
---

<PageLayout title="Inicio">
  <PublicRoute>
    <!-- CONTENEDOR GENERAL -->
    <div class="flex min-h-screen">
      <!-- BARRA LATERAL (SIDEBAR) -->
      <aside class="hidden w-64 flex-col justify-between border-r border-gray-200 bg-slate-900 p-6 text-white md:flex dark:border-gray-800">
        <div>
          <div class="mb-10 flex items-center gap-3">
            <span class="text-2xl">📦</span>
            <h2 class="text-xl font-bold tracking-tight">StockSaaS</h2>
          </div>
          <!-- Menú Dinámico con JavaScript (Crea los enlaces automáticamente) -->
          <nav id="sidebar-menu" class="flex flex-col gap-2">
            {menuItems.map((item) => (
              <a 
                href={item.href} 
                data-link={item.href} 
                class="px-4 py-3 text-sm font-medium transition-colors rounded-lg text-slate-400 hover:bg-slate-800 hover:text-white"
              >
              {item.label}
              </a>
            ))}
          </nav>
        </div>
        <div class="flex items-center gap-3 border-t border-slate-800 pt-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-600 font-bold text-white">
            🏭
          </div>
          <div class="truncate">
            <p class="truncate text-sm font-semibold">Administrador</p>
            <p class="truncate text-xs text-slate-400">{nombreTienda}</p>
          </div>
        </div>
      </aside>
      <!-- CONTENIDO PRINCIPAL -->  
      <main class="mx-auto w-full max-w-7xl flex-1 p-6 md:p-10">
        <!-- ENCABEZADO -->
        <header class="mb-8 flex flex-col justify-between gap-4 sm:flex-row sm:items-center">
          <div>
            <h1 class="text-2xl font-bold tracking-tight text-gray-900 md:text-3xl dark:text-white">Dashboard Comercial</h1>
            <p class="mt-1 text-sm text-gray-500 md:text-base dark:text-gray-400">
              Estado actual de tus productos y flujo de caja.
            </p>
          </div>
          <div>
            <button id="btn-registrar-venta"
              class="w-full rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700 sm:w-auto">
              Registrar Venta +
            </button>
          </div>
        </header>
        <!-- TARJETAS DE MÉTRICAS (KPIs) -->
        <section class="mb-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <!-- Tarjeta Ventas -->
          <div class="rounded-xl border-b border-x border-t-4 border-gray-200 border-t-emerald-500 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <div class="mb-3 flex items-center justify-between text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              <span>Ventas de Hoy</span>
              <span class="text-xl">💵</span>
            </div>
            <p id="kpi-ventas" class="text-3xl font-bold text-gray-900 dark:text-white">
              {divisa}{metricas.ventasHoy}
            </p>
          </div>
          <!-- Tarjeta Restock -->
          <div class="rounded-xl border-b border-x border-t-4 border-gray-200 border-t-red-500 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <div class="mb-3 flex items-center justify-between text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              <span>Alertas de Restock</span>
              <span class="text-xl">⚠️</span>
            </div>
            <p id="kpi-restock" class="text-3xl font-bold text-gray-900 dark:text-white">
              {metricas.alertasRestock}
            </p>
          </div>
          <!-- Tarjeta Total Items -->
          <div class="rounded-xl border-b border-x border-t-4 border-gray-200 border-t-blue-500 bg-white p-6 shadow-sm sm:col-span-2 lg:col-span-1 dark:border-gray-700 dark:bg-gray-800">
            <div class="mb-3 flex items-center justify-between text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              <span>Items Registrados</span>
              <span class="text-xl">📦</span>
            </div>
            <p class="text-3xl font-bold text-gray-900 dark:text-white">
              {metricas.totalProductos}
            </p>
          </div>
        </section>
        <!-- SECCIÓN DE LA TABLA -->
        <section class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
              🚨 Productos en Stock Crítico
            </h3>
            <p class="mt-1 text-s text-gray-500 dark:text-gray-400">
              Artículos que requieren reposición inmediata de stock.
            </p>
          </div>
          <!-- Stock Crítico -->
          <div class="w-full overflow-x-auto">
            <table class="w-full border-collapse text-left text-sm">
              <thead>
                <tr class="bg-gray-50 text-xs font-semibold uppercase tracking-wider text-gray-500 dark:bg-gray-700/50 dark:text-gray-400">
                  <th class="border-b border-gray-200 p-4 dark:border-gray-700">Producto</th>
                  <th class="border-b border-gray-200 p-4 dark:border-gray-700">Stock Actual</th>
                  <th class="border-b border-gray-200 p-4 dark:border-gray-700">Mínimo</th>
                  <th class="border-b border-gray-200 p-4 dark:border-gray-700">Acción</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                {productosCriticos.map((prod) => {
                  const porcentaje = Math.min((prod.stock / 10) * 100, 100);
                  // Llamas a tu función que ya tienes en utils.js
                  const colorClase = stockColor(prod.stock, prod.minimo);
                  return (
                    <tr data-id={prod.id} class="product-row transition-colors hover:bg-gray-50/10">
                      <td class="p-4">
                        <div class="font-medium text-gray-900 dark:text-white">{prod.nombre}</div>
                        <div class="text-xs text-gray-500">{prod.categoria}</div>
                      </td>
                      <td class="stock-cell p-4 font-semibold" data-stock={prod.stock} data-min={prod.minimo}>
                        <span class={colorClase}>{prod.stock} u.</span>
                        <div class="h-1.5 w-24 mt-1 rounded-full bg-gray-200">
                          <div class={`h-full rounded-full ${colorClase.replace('text', 'bg')}`} style={`width: ${porcentaje}%`}></div>
                        </div>
                      </td>
                      <td class="p-4 text-gray-500">Mín: {prod.minimo}</td>
                      <td class="p-4 flex items-center gap-2">
                        <input type="text" class="input-cantidad w-16 rounded border p-1 text-center [appearance:textfield]" value="1" min="1" />
                        <button class="btn-restock rounded bg-blue-600 px-3 py-1.5 text-xs font-bold text-white">Surtir</button>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </section>
        <!-- MODAL DE SIMULACIÓN DE VENTA -->
        <div id="modal-venta" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4 backdrop-blur-sm">
          <div class="w-full max-w-sm rounded-xl border border-gray-200 bg-white p-6 shadow-xl dark:border-gray-700 dark:bg-gray-800">
            <h2 class="mb-4 text-xl font-bold text-gray-900 dark:text-white">
              Simular Nueva Venta
            </h2>
            <div class="mb-6 flex flex-col gap-4">
              <!-- Selector de Producto -->
              <div>
                <label class="mb-1 block text-xs font-medium uppercase text-gray-500 dark:text-gray-400">
                  Seleccionar Producto vendido
                </label>
                <select id="select-producto" class="w-full rounded-lg border border-gray-300 bg-white p-2.5 text-sm text-gray-900 outline-none focus:ring-2 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-700 dark:text-white">
                  <option value="" data-precio="0">Seleccione un artículo</option>
                  {productosCriticos.map((prod) => (
                    <option value={prod.id} data-precio={prod.precio}>
                      {prod.nombre} (Stock: {prod.stock})
                    </option>
                  ))}
                </select>
              </div>
              <!-- Input del Monto (Relleno automático, pero EDITABLE) -->
              <div>
                <label class="mb-1 block text-xs font-medium uppercase text-gray-500 dark:text-gray-400">
                  Monto de la venta ({divisa})
                </label>
                <input
                  id="input-monto"
                  type="number"
                  step="0.01"
                  value="0"
                  class="w-full rounded-lg border border-gray-300 bg-transparent p-2.5 text-gray-900 outline-none focus:ring-2 focus:ring-blue-500 dark:border-gray-600 dark:text-white"
                />
              </div>
            </div>

            <div class="flex justify-end gap-3">
              <button
                id="btn-cerrar-modal"
                class="px-4 py-2 text-sm font-medium text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200"
              >
                Cancelar
              </button>
              <button
                id="btn-confirmar-venta"
                class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-emerald-700"
              >
                Aplicar Venta
              </button>
            </div>
          </div>
        </div>
      </main>
    </div>
  </PublicRoute>
</PageLayout>

<script>
  import { calcularAlertasRestock } from '../features/dashboard/utils.js';

  // 1. MARCAR BOTÓN ACTIVO
  const rutaActual = window.location.pathname;
  document.querySelectorAll('#sidebar-menu a').forEach((enlace) => {
    if (enlace.getAttribute('data-link') === rutaActual) {
      enlace.classList.add('border-l-4', 'border-blue-500', 'bg-slate-800', 'text-white');
    }
  });

  // 2. CONTROL DEL MODAL
  const modalVenta = document.getElementById('modal-venta');
  const btnAbrirModal = document.getElementById('btn-registrar-venta');
  const btnCerrarModal = document.getElementById('btn-cerrar-modal');
  const selectProducto = document.getElementById('select-producto');
  const inputMonto = document.getElementById('input-monto');
  const btnConfirmarVenta = document.getElementById('btn-confirmar-venta');
  const kpiRestock = document.getElementById('kpi-restock');

  btnAbrirModal.addEventListener('click', () => modalVenta.classList.replace('hidden', 'flex'));

  const cerrarModalVenta = () => {
    modalVenta.classList.replace('flex', 'hidden');
    selectProducto.value = "";
    inputMonto.value = "0";
  };
  btnCerrarModal.addEventListener('click', cerrarModalVenta);

  selectProducto.addEventListener('change', () => {
    const opcion = selectProducto.options[selectProducto.selectedIndex];
    inputMonto.value = opcion.getAttribute('data-precio') || "0";
  });

  // 3. APLICAR VENTA
  btnConfirmarVenta.addEventListener('click', () => {
    const productoId = selectProducto.value;
    if (!productoId) return alert("Selecciona un producto.");

    const fila = document.querySelector(`.product-row[data-id="${productoId}"]`);
    const celdaStock = fila.querySelector('.stock-cell');
    let stock = parseInt(celdaStock.getAttribute('data-stock'));

    if (stock <= 0) return alert("❌ Sin stock disponible.");

    stock -= 1;
    celdaStock.setAttribute('data-stock', stock.toString());
    const span = celdaStock.querySelector('span');
    span.textContent = `${stock} u.`;
    span.className = stock === 0 ? "text-red-500 font-bold" : "text-gray-700 dark:text-gray-300";

    const kpiVentas = document.getElementById('kpi-ventas');
    const total = parseFloat(kpiVentas.textContent.replace('$', '')) + parseFloat(inputMonto.value);
    kpiVentas.textContent = `$${total.toFixed(2)}`;

    kpiRestock.textContent = calcularAlertasRestock().toString();
    cerrarModalVenta();
  });

  // 4. LÓGICA DE REABASTECIMIENTO
  document.querySelectorAll('.btn-restock').forEach((boton) => {
  boton.addEventListener('click', (e) => {
    const fila = e.target.closest('.product-row');
    const celdaStock = fila.querySelector('.stock-cell');
    const inputCantidad = fila.querySelector('.input-cantidad');
    const minimo = parseInt(celdaStock.getAttribute('data-min'));
    
    const cantidadSurtir = parseInt(inputCantidad.value);
    
    if (isNaN(cantidadSurtir) || cantidadSurtir <= 0) {
      alert("Por favor ingresa una cantidad válida.");
      return;
    }

    // 1. Actualizar stock lógico
    let stockActual = parseInt(celdaStock.getAttribute('data-stock')) + cantidadSurtir;
    celdaStock.setAttribute('data-stock', stockActual.toString());

    // 2. ACTUALIZAR EL SPAN EXISTENTE (Ya no usamos 'const' aquí)
    let span = celdaStock.querySelector('span');
    span.textContent = `${stockActual} u.`;
    
    // Aplicar lógica de colores dinámica
    if (stockActual < minimo) {
        span.className = "text-red-600 font-bold";
    } else if (stockActual >= 5 && stockActual <= 9) {
        span.className = "text-amber-500 font-bold";
    } else {
        span.className = "text-emerald-600 font-bold";
    }

    // 3. ACTUALIZAR BARRA VISUAL
    const barra = fila.querySelector('.h-full');
    const nuevoPorcentaje = Math.min((stockActual / 10) * 100, 100); // Usamos 10 como base para el verde
    
    barra.style.width = `${nuevoPorcentaje}%`;
    barra.className = `h-full rounded-full transition-all duration-500 ${
        stockActual < minimo ? 'bg-red-500' : (stockActual <= 9 ? 'bg-amber-500' : 'bg-emerald-500')
    }`;

    // 4. Recalcular alertas totales
    document.getElementById('kpi-restock').textContent = calcularAlertasRestock().toString();
    
    // Limpiar input
    inputCantidad.value = "1";
  });
});
</script>