---
import Button from '../components/Button.astro';
import Spinner from '../components/Spinner.astro';
import PageLayout from '../layout/PageLayout.astro';
import PrivateRoute from '../layout/PrivateRoute.astro';
---

<PageLayout title="Registro">
  <div class="flex items-center justify-center min-h-screen py-10">
    <form
      id="signup-form"
      class="p-8 rounded-lg border border-gray-300 dark:border-gray-600 w-full max-w-sm flex flex-col gap-6 bg-white dark:bg-gray-800"
    >
      <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-100 text-center">Crear Cuenta </h2>

      <div class="relative flex flex-col gap-1">
        <label for="name" class="text-sm font-medium text-gray-700 dark:text-gray-300">Nombre Completo</label>
        <input
          type="text"
          id="name"
          class="w-full border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors"
          placeholder="Ej. Gabriel Garcia"
        />
      </div>

      <div class="relative flex flex-col gap-1">
        <label for="email" class="text-sm font-medium text-gray-700 dark:text-gray-300">Correo Corporativo</label>
        <div class="relative">
          <input
            type="email"
            id="email"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-md py-2 pl-3 pr-10 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors"
            placeholder="tu@empresa.com"
          />
          <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
            <ion-icon id="email-check" name="checkmark-circle" class="text-green-500 text-xl hidden"></ion-icon>
            <ion-icon id="email-cross" name="close-circle" class="text-red-500 text-xl hidden"></ion-icon>
          </div>
        </div>
      </div>

      <div class="relative flex flex-col gap-1">
        <label for="password" class="text-sm font-medium text-gray-700 dark:text-gray-300">Contraseña</label>
        <div class="relative">
          <input
            type="password"
            id="password"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-md py-2 pl-3 pr-10 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors"
            placeholder="••••••••"
          />
          <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
            <ion-icon id="password-check" name="checkmark-circle" class="text-green-500 text-xl hidden"></ion-icon>
            <ion-icon id="password-cross" name="close-circle" class="text-red-500 text-xl hidden"></ion-icon>
          </div>
        </div>
        <p class="text-xs text-gray-500 dark:text-gray-400">Min 8 caracteres, Mayúscula, Número y Especial.</p>
      </div>

      <button
        type="submit"
        class="flex justify-center items-center gap-4 w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-md transition-colors cursor-pointer"
      >
        Registrar
        <Spinner color="fill-blue-800" />
      </button>
    </form>
  </div>
</PageLayout>

<script>
  // Validacion Regex Variables
  import { z } from 'astro/zod';
  import ky, { HTTPError } from 'ky';
  import { showToast } from '../components/notification/notification';

  // 1. Actualizamos el Schema de Zod (Frontend) para incluir name y department
  const formUserSchema = z.object({
    name: z.string().min(3, { message: 'Nombre obligatorio' }),
    email: z.string().email({ message: 'Email inválido' }),
    password: z.string().regex(/^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)[a-zA-Z\d\S]{8,}$/, {
      message: 'La contraseña no cumple los requisitos',
    }),
  });

  // Elementos del DOM
  const form = document.querySelector('#signup-form');
  const nameInput = document.querySelector('#name');
  const emailInput = document.querySelector('#email');
  const passwordInput = document.querySelector('#password');
  const spinner = document.querySelector('#spinner');

  // Función de validación visual (mantenemos tu lógica)
  function validateField(inputElement, success) {
    const nextDiv = inputElement.nextElementSibling;
    if (!nextDiv || !nextDiv.children.length) return; // Evitar error en inputs sin iconos
    const checkIcon = nextDiv.children[0];
    const crossIcon = nextDiv.children[1];
    const value = inputElement.value;

    if (value.length === 0) {
      checkIcon?.classList.add('hidden');
      crossIcon?.classList.add('hidden');
      return;
    }

    if (success) {
      checkIcon?.classList.remove('hidden');
      crossIcon?.classList.add('hidden');
    } else {
      checkIcon?.classList.add('hidden');
      crossIcon?.classList.remove('hidden');
    }
  }

  // Eventos de validación en tiempo real
  emailInput.addEventListener('input', () => {
    const { success } = formUserSchema.pick({ email: true }).safeParse({ email: emailInput.value });
    validateField(emailInput, success);
  });

  passwordInput.addEventListener('input', () => {
    const { success } = formUserSchema.pick({ password: true }).safeParse({ password: passwordInput.value });
    console.log(success);
    validateField(passwordInput, success);
  });

  // Manejo del Submit
  form.addEventListener('submit', async (e) => {
  e.preventDefault();

  const data = {
    name: nameInput.value,
    email: emailInput.value,
    password: passwordInput.value,
  };

  // 1. Validar con el Schema (Asegúrate de actualizar formUserSchema)
  const { success, error } = formUserSchema.safeParse(data);

  if (success) {
    try {
      spinner?.classList.remove('hidden');
      
      // 2. Usar ky para el POST
      const response = await ky.post('/api/user', { json: data }).json();
      
      showToast({
        type: 'success',
        text: `¡Éxito! Verifica el correo enviado a ${response.email}`,
      });

      form.reset(); 

    } catch (err) {
      // 3. Manejo de errores robusto
      let message = 'Error al registrar';
      
      if (err instanceof HTTPError) {
        try {
          // Intentamos obtener el error del backend
          const errorData = await err.response.json();
          message = errorData.error || message;
        } catch (parseError) {
          // Si el JSON falla, usamos el mensaje de estado HTTP
          message = `Error ${err.response.status}: ${err.response.statusText}`;
          console.log(parseError);
          
        }
      }
      
      showToast({ type: 'error', text: message });
    } finally {
      spinner?.classList.add('hidden');
    }
  } else {
    // 4. Mostrar errores de validación de Zod
    const fieldErrors = error.flatten().fieldErrors;
    console.log(fieldErrors); // Para que veas qué campo está fallando
    
    showToast({ 
      type: 'error', 
      text: 'Por favor, rellena todos los campos correctamente.' 
    });
  }
});
</script>